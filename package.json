{
  "name": "jekkiart",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "next build && npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion --skipNextBuild",
    "build:clean": "node -e \"const fs = require('fs'); ['.next', '.open-next', 'out'].forEach(d => fs.rmSync(d, { recursive: true, force: true }))\" && npm run build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run build && npx @opennextjs/cloudflare preview",
    "deploy": "npm run build && npx @opennextjs/cloudflare deploy",
    "upload": "npm run build && npx @opennextjs/cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.2",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.84.0"
  }
}